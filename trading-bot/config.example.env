# Copy to .env (never commit .env)

# SIM | CSV (SIM uses built-in fake walk; CSV uses OHLCV file)
MODE=SIM

# For MODE=CSV — path to CSV with columns: time,open,high,low,close,volume
# CSV_PATH=./data/sample_ohlcv.csv

INITIAL_BALANCE_USD=10000
POSITION_SIZE_USD=100
SYMBOL=BTC-USD

# Simple MA crossover example (tune for learning only)
FAST_MA=5
SLOW_MA=15
